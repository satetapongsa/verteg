# Server Settings
PORT=5000
NODE_ENV=development

# JWT Security Secrets (Must be random high-entropy strings in production)
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# Frontend client URL configuration
CORS_ORIGIN=http://localhost:5173

# Initial Seeding Credentials (Only used during prisma:seed)
SEED_ADMIN_PASSWORD=your_admin_seeding_password_here
SEED_USER_PASSWORD=your_user_seeding_password_here
